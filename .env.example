# Copy to .env and adjust. Loaded by docker-compose and the apps.

# --- Database ---
POSTGRES_USER=amina
POSTGRES_PASSWORD=amina
POSTGRES_DB=amina_travel

# --- Backend API ---
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__HotelsDb=Host=localhost;Port=5432;Database=amina_travel;Username=amina;Password=amina;SearchPath=hotels

# --- Web frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080

# --- Images (admin CRUD uploads) ---
# From your Cloudinary dashboard: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# --- Suppliers (sandbox credentials — fill when integrating) ---
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# TBO_USERNAME=
# TBO_PASSWORD=

# --- Payments — Clictopay / SMT (sandbox) ---
# Leave UserName/Password empty to use the in-site mock bank page (no credentials needed in dev).
# Fill both to activate the real hosted Clictopay flow. Map to Payments:Clictopay:* via "__".
Payments__Clictopay__UserName=
Payments__Clictopay__Password=
Payments__Clictopay__BaseUrl=https://test.clictopay.com
Payments__Clictopay__WebBaseUrl=http://localhost:3000
STRIPE_SECRET_KEY=

# --- Hotels supplier — TunisiaBeds / OS-TRAVEL ---
TUNISIABEDS_LOGIN=
TUNISIABEDS_PASSWORD=
