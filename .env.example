# Copy to .env and adjust. Loaded by docker-compose and the apps.

# --- Database ---
POSTGRES_USER=amina
POSTGRES_PASSWORD=amina
POSTGRES_DB=amina_travel

# --- Backend API ---
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__HotelsDb=Host=localhost;Port=5432;Database=amina_travel;Username=amina;Password=amina;SearchPath=hotels

# --- Web frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080

# --- Suppliers (sandbox credentials — fill when integrating) ---
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# TBO_USERNAME=
# TBO_PASSWORD=

# --- Payments (sandbox) ---
CLICTOPAY_MERCHANT_ID=
STRIPE_SECRET_KEY=
