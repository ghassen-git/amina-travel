# Copy to `.env` on the server and fill in.  NEVER commit the filled file.
#   cp .env.production.example .env && nano .env

# --- Domain (drives nginx, CORS, and the API URL compiled into the frontend) ---
DOMAIN=example.com

# --- Database (pick strong values; only Postgres sees these) ---
POSTGRES_USER=amina
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=amina_travel

# --- Auth: JWT signing secret (REQUIRED, >=32 chars, keep stable or all sessions invalidate) ---
JWT_SIGNING_KEY=CHANGE_ME_long_random_secret_min_32_chars

# --- Payments: Clictopay / SMT (leave empty to use the in-site mock bank page) ---
CLICTOPAY_USERNAME=
CLICTOPAY_PASSWORD=
CLICTOPAY_BASE_URL=https://test.clictopay.com

# --- Hotel supplier: TunisiaBeds ---
TUNISIABEDS_LOGIN=
TUNISIABEDS_PASSWORD=

# --- Image uploads: Cloudinary (empty = uploads return 503) ---
CLOUDINARY_URL=

# --- Contact form: SMTP (Gmail needs an APP password) ---
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
